@model HospitalManagement.Core.DTOs.Patients.PatientDto

@{
    ViewData["Title"] = "Delete Patient";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger">

                <!-- Warning Header -->
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">⚠️ Confirm Delete</h4>
                </div>

                <!-- Confirmation Message -->
                <div class="card-body text-center py-4">
                    <i class="bi bi-exclamation-triangle display-1 text-warning mb-3"></i>

                    <h5 class="mb-3">Are you sure you want to delete this patient?</h5>

                    <!-- Patient Summary (so user knows what they're deleting) -->
                    <div class="alert alert-light border mb-4">
                        <p class="mb-1"><strong>Name:</strong> @Model.FullName</p>
                        <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
                        <p class="mb-0"><strong>Phone:</strong> @Model.Phone</p>
                    </div>

                    <p class="text-muted small">
                        <strong>Note:</strong> This is a soft delete.
                        The patient record will be hidden but can be recovered by an administrator.
                    </p>
                </div>

                <!-- Confirm/Cancel Buttons -->
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary px-4">
                            ❌ Cancel
                        </a>

                        <!-- Form that actually performs the delete -->
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger px-4">
                                ✅ Yes, Delete Patient
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>