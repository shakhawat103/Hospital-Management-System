@model HospitalManagement.Core.DTOs.Patients.PatientDto

@{
    ViewData["Title"] = "Patient Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <!-- Header -->
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">👤 @Model.FullName</h4>
                    <a asp-action="Index" class="btn btn-light btn-sm">← Back</a>
                </div>

                <!-- Patient Info -->
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Patient ID</dt>
                        <dd class="col-sm-8"><strong>#@Model.Id</strong></dd>

                        <dt class="col-sm-4 text-muted">Full Name</dt>
                        <dd class="col-sm-8">@Model.FullName</dd>

                        <dt class="col-sm-4 text-muted">Age</dt>
                        <dd class="col-sm-8">@Model.Age years old</dd>

                        <dt class="col-sm-4 text-muted">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</dd>

                        <dt class="col-sm-4 text-muted">Phone</dt>
                        <dd class="col-sm-8">
                            <a href="tel:@Model.Phone" class="text-decoration-none">@Model.Phone</a>
                        </dd>

                        <dt class="col-sm-4 text-muted">Email</dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                        </dd>

                        <dt class="col-sm-4 text-muted">Registered</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
                    </dl>
                </div>

                <!-- Action Buttons -->
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">✏️ Edit</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Delete @Model.FullName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">🗑️ Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>