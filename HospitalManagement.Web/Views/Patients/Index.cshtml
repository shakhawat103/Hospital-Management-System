@using HospitalManagement.Core.DTOs.Patients
@* @model IEnumerable<HospitalManagement.Core.DTOs.Patients.PatientDto> *@
@model HospitalManagement.Core.Common.PagedResult<PatientDto>
@{
    ViewData["Title"] = "Patients";
    var pageNumber = ViewBag.CurrentPage as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 10;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
    var searchTerm = ViewBag.SearchTerm as string;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Patient List</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Add New Patient</a>
    </div>
    <!-- 🔍 Search & Filter Section -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">

                <!-- Search Input -->
                <div class="col-md-5">
                    <label class="form-label small text-muted">🔍 Search Patients</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="search"
                               class="form-control"
                               placeholder="Name, email, or phone..."
                               value="@searchTerm"
                               aria-label="Search">
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <a asp-action="Index"
                               asp-route-page="1"
                               asp-route-pageSize="@pageSize"
                               class="btn btn-outline-secondary"
                               title="Clear search">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        }
                    </div>
                    @* <small class="text-muted">Searches first name, last name, email, and phone</small> *@
                </div>

                <!-- Page Size Selector -->
                <div class="col-md-3">
                    <label class="form-label small text-muted">Items per page</label>
                    <select name="pageSize" class="form-select" asp-items="@(new[] {
                                                                                    new SelectListItem { Value = "5", Text = "5" },
                                                                                    new SelectListItem { Value = "10", Text = "10", Selected = pageSize == 10 },
                                                                                    new SelectListItem { Value = "25", Text = "25", Selected = pageSize == 25 },
                                                                                    new SelectListItem { Value = "50", Text = "50", Selected = pageSize == 50 }
                                                                                })" onchange="this.form.submit()">
                    </select>
                </div>

                <!-- Search Button -->
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                </div>

                <!-- Reset Button -->
                <div class="col-md-2">
                    <a asp-action="Index"
                       asp-route-page="1"
                       asp-route-pageSize="10"
                       class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Show search results info -->
    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div class="alert alert-info py-2 mb-3">
            <i class="bi bi-info-circle me-2"></i>
            Showing results for "<strong>@searchTerm</strong>"
            (@totalCount found)
            <a asp-action="Index" asp-route-page="1" asp-route-pageSize="@pageSize" class="ms-2 small">
                Clear search
            </a>
        </div>
    }

    <!-- Patients Table -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model?.Items?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th>Age</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@p.FullName</strong></td>
                                    <td>@p.Age yrs</td>
                                    <td>@p.Phone</td>
                                    <td>@p.Email</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@p.Id"
                                               class="btn btn-outline-info">Details</a>
                                            <a asp-action="Edit" asp-route-id="@p.Id"
                                               class="btn btn-outline-warning">Edit</a>
                                            <form asp-action="Delete" asp-route-id="@p.Id"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete @p.FullName?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <p class="mt-3 text-muted fs-5">
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            @:No patients found matching "<strong>@searchTerm</strong>"
                            <br>
                            <small class="text-muted">Try different keywords or <a asp-action="Index">clear search</a></small>
                        }
                        else
                        {
                            @:No patients found.
                            <br>
                            <a asp-action="Create" class="btn btn-primary mt-2">Add Your First Patient</a>
                        }
                    </p>
                </div>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", Model)

</div>