@model IEnumerable<HospitalManagement.Core.DTOs.Patients.PatientDto>

@{
    ViewData["Title"] = "Patients";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">🏥 Patient List</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Add New Patient</a>
    </div>

    <!-- Patients Table -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th>Age</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@p.FullName</strong></td>
                                    <td>@p.Age yrs</td>
                                    <td>@p.Phone</td>
                                    <td>@p.Email</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@p.Id"
                                               class="btn btn-outline-info">👁️</a>
                                            <a asp-action="Edit" asp-route-id="@p.Id"
                                               class="btn btn-outline-warning">✏️</a>
                                            <form asp-action="Delete" asp-route-id="@p.Id"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete @p.FullName?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger">🗑️</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <p class="mt-3 text-muted">No patients found.</p>
                    <a asp-action="Create" class="btn btn-primary">Add Your First Patient</a>
                </div>
            }
        </div>
    </div>
</div>