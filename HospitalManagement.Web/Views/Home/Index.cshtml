@using HospitalManagement.Core.Entities.Identity
@using Microsoft.AspNetCore.Identity
@using HospitalManagement.Core.Entities
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Dashboard";

    // 💡 Safely get current user details
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.FullName ?? "User";

    // Determine primary role for UI customization
    var userRole = User.IsInRole("Admin") ? "Admin" :
                   User.IsInRole("Doctor") ? "Doctor" :
                   User.IsInRole("Patient") ? "Patient" : "Normal";
}

<div class="container-fluid py-4 px-lg-4">

    <!-- 🎉 Welcome Banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-primary text-white border-0 shadow-sm">
                <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap">
                    <div>
                        <h2 class="fw-bold mb-1">Welcome back, @displayName! 👋</h2>
                        <p class="mb-0 opacity-90">
                            Logged in as <strong>@userRole</strong> | @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                        </p>
                    </div>
                    <div class="mt-3 mt-md-0">
                        <span class="badge bg-light text-primary px-3 py-2 fs-6">
                            <i class="bi bi-hospital me-1"></i> MediCare HMS
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 🧭 Role-Specific Quick Action Cards -->
    <div class="row g-4 mb-4">

        @* 🔑 ADMIN DASHBOARD *@
        @if (User.IsInRole("Admin"))
        {
            <div class="col-xl-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="card-body text-center p-4">
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-people fs-2 text-primary"></i>
                        </div>
                        <h5 class="card-title mb-2">Patients</h5>
                        <p class="text-muted small mb-3">Manage registrations & records</p>
                        <a asp-controller="Patients" asp-action="Index" class="btn btn-outline-primary btn-sm w-100">View All</a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="card-body text-center p-4">
                        <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-person-badge fs-2 text-success"></i>
                        </div>
                        <h5 class="card-title mb-2">Doctors</h5>
                        <p class="text-muted small mb-3">Staff management & schedules</p>
                        <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-success btn-sm w-100">Manage</a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="card-body text-center p-4">
                        <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-calendar-check fs-2 text-info"></i>
                        </div>
                        <h5 class="card-title mb-2">Appointments</h5>
                        <p class="text-muted small mb-3">Monitor daily schedules</p>
                        <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-info btn-sm w-100">View Calendar</a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="card-body text-center p-4">
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-shield-lock fs-2 text-warning"></i>
                        </div>
                        <h5 class="card-title mb-2">Roles & Access</h5>
                        <p class="text-muted small mb-3">Configure permissions</p>
                        <a asp-controller="Roles" asp-action="Index" class="btn btn-outline-warning btn-sm w-100">Configure</a>
                    </div>
                </div>
            </div>
        }

        @* 🩺 DOCTOR DASHBOARD *@
        else if (User.IsInRole("Doctor"))
        {
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-calendar-check fs-2 text-primary"></i>
                    </div>
                    <h5 class="card-title mb-2">Today's Schedule</h5>
                    <p class="text-muted small mb-3">View upcoming appointments</p>
                    <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-primary btn-sm w-100">Open Calendar</a>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-people fs-2 text-success"></i>
                    </div>
                    <h5 class="card-title mb-2">My Patients</h5>
                    <p class="text-muted small mb-3">Access medical records</p>
                    <a asp-controller="Patients" asp-action="Index" class="btn btn-outline-success btn-sm w-100">View List</a>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-journal-medical fs-2 text-info"></i>
                    </div>
                    <h5 class="card-title mb-2">Prescriptions</h5>
                    <p class="text-muted small mb-3">Write & review scripts</p>
                    <a asp-controller="Prescriptions" asp-action="Index" class="btn btn-outline-info btn-sm w-100">Manage</a>
                </div>
            </div>
        </div>
        }

        @* 🧑‍🦱 PATIENT DASHBOARD *@
        else if (User.IsInRole("Patient"))
        {
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-calendar-plus fs-2 text-primary"></i>
                    </div>
                    <h5 class="card-title mb-2">Book Appointment</h5>
                    <p class="text-muted small mb-3">Schedule a new visit</p>
                        <a asp-controller="Appointments" asp-action="BrowseDoctors" class="btn btn-outline-primary btn-sm w-100">Schedule Now</a>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-clock-history fs-2 text-warning"></i>
                    </div>
                    <h5 class="card-title mb-2">My Visits</h5>
                    <p class="text-muted small mb-3">View appointment history</p>
                        <a asp-controller="Appointments" asp-action="MyAppointments" class="btn btn-outline-warning btn-sm w-100">View History</a>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-person-circle fs-2 text-success"></i>
                    </div>
                    <h5 class="card-title mb-2">My Profile</h5>
                    <p class="text-muted small mb-3">Update contact details</p>
                    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-success btn-sm w-100">Edit Info</a>
                </div>
            </div>
            </div>
        }
        @* 🏠 NORMAL / GUEST UI *@
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm bg-light">
                    <div class="card-body p-5 text-center">
                        <div class="mb-4">
                            <i class="bi bi-shield-lock display-1 text-muted opacity-50"></i>
                        </div>
                        <h3 class="fw-bold">Access Restricted</h3>
                        <p class="text-muted mx-auto" style="max-width: 500px;">
                            You are currently viewing the public dashboard. To access medical records, book appointments, or manage staff, please sign in to your account.
                        </p>
                        @* <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                            <a asp-area="Identity" class="btn btn-primary btn-lg px-4 me-sm-3" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                            </a>
                            <a asp-area="Identity" class="btn btn-outline-secondary btn-lg px-4" asp-controller="Account" asp-action="Register">
                                Create Account
                            </a>
                        </div> *@
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- 📊 Dashboard Bottom Section -->
    <div class="row g-4">
        <!-- Quick Stats / Activity Panel -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">📈 Quick Overview</h5>
                    <span class="badge bg-secondary">Live Data</span>
                </div>
                <div class="card-body text-center py-5 text-muted">
                    <i class="bi bi-graph-up-arrow display-4 mb-3 d-block"></i>
                    <p class="mb-2 fw-medium">Analytics & reporting will appear here</p>
                    <small>Connect this section to your service layer to show real-time counts, upcoming appointments, or revenue stats.</small>
                </div>
            </div>
        </div>

        <!-- Hospital Notices -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">📢 Hospital Notices</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex align-items-center px-4 py-3">
                            <i class="bi bi-info-circle text-primary me-3"></i>
                            <span>Clinic hours updated: 9 AM - 6 PM</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center px-4 py-3">
                            <i class="bi bi-check-circle text-success me-3"></i>
                            <span>Online payment now available</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center px-4 py-3">
                            <i class="bi bi-exclamation-triangle text-warning me-3"></i>
                            <span>Flu vaccination drive next week</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ✨ Optional: Add subtle hover effects -->
<style>
    .hover-shadow {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-4px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
        }
</style>