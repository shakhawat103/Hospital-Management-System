@{
    ViewData["Title"] = "Coming Soon";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="card shadow-lg border-0 text-center p-5" style="border-radius: 24px; max-width: 600px; background: white;">

        <div class="mb-4">
            <div class="display-1 text-primary opacity-25">
                <i class="bi bi-gear-wide-connected spin-slow"></i>
            </div>
        </div>

        <h2 class="fw-bold text-dark mb-3">Feature Under Development</h2>
        <p class="text-muted px-4">
            Our engineering team is currently building this module to enhance our healthcare services.
            We are ensuring it meets our high standards for security and clinical accuracy.
        </p>

        <div class="mt-4 mb-2 d-flex justify-content-between px-2">
            <span class="small fw-bold text-primary">Development Progress</span>
            <span class="small text-muted">75%</span>
        </div>
        <div class="progress mb-4" style="height: 10px; border-radius: 10px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                 role="progressbar" style="width: 75%"></div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i>Go Back
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 shadow-sm">
                Dashboard
            </a>
        </div>

        <div class="mt-5">
            <p class="x-small text-uppercase tracking-wider text-muted mb-0" style="font-size: 0.7rem; letter-spacing: 2px;">
                Expected Release: Q3 2026
            </p>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .spin-slow {
        display: inline-block;
        animation: spin 8s linear infinite;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .x-small {
        font-size: 0.75rem;
    }
</style>