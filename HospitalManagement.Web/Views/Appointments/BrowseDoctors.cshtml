@model IEnumerable<HospitalManagement.Core.DTOs.Appointments.DoctorCardDto>

@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2>👨‍⚕️ Available Doctors</h2>
            <p class="text-muted">Select a doctor to book an appointment</p>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="row g-4">
            @foreach (var doctor in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 hover-shadow">
                        <!-- Doctor Photo -->
                        <img src="@(doctor.PhotoUrl ?? "/images/default-doctor.png")"
                             class="card-img-top"
                             alt="@doctor.FullName"
                             style="height: 200px; object-fit: cover;"
                             onerror="this.src='/images/default-doctor.png'">

                        <div class="card-body">
                            <h5 class="card-title">@doctor.FullName</h5>
                            <p class="card-text text-primary fw-medium">@doctor.Specialty</p>

                            <div class="mb-3">
                                <small class="text-muted d-block">Consultation Fee</small>
                                <strong class="text-success">@doctor.FormattedFee</strong>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block">Contact</small>
                                <small>📞 @doctor.Phone</small><br>
                                <small>✉️ @doctor.Email</small>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0">
                            <a asp-action="Book" asp-route-doctorId="@doctor.Id"
                               class="btn btn-primary w-100">
                                📅 Book Appointment
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            No doctors available at the moment. Please check back later.
        </div>
    }
</div>

<style>
    .hover-shadow { transition: transform 0.2s, box-shadow 0.2s; }
    .hover-shadow:hover { transform: translateY(-4px); box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1) !important; }
</style>