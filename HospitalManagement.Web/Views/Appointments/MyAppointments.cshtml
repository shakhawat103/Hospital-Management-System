@using HospitalManagement.Core.Enums
@model IEnumerable<HospitalManagement.Core.DTOs.Appointments.AppointmentDto>

@{
    ViewData["Title"] = "My Appointments";
}

@* Custom CSS for the Hover Effect *@
<style>
    .appointment-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .appointment-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }
</style>

<div class="container-fluid py-5" style="max-width: 1240px;">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3 border-bottom pb-4">
        <div>
            <h1 class="fw-bold h2 mb-1 text-dark">My Health Dashboard</h1>
            <p class="text-muted mb-0 fs-5">Track and manage your medical consultations.</p>
        </div>
        <a asp-action="BrowseDoctors" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm hover-lift">
            <i class="bi bi-calendar-plus me-2"></i>Book New Appointment
        </a>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="row g-4">
            @foreach (var appt in Model.OrderBy(a => a.Status == AppointmentStatus.Scheduled ? 0 : 1).ThenBy(a => a.AppointmentDate))
            {
                var isUpcoming = appt.Status == AppointmentStatus.Scheduled && appt.AppointmentDate > DateTime.Now;

                // --- Dynamic Color Mapping Logic ---
                string cardTopBorderColor = "border-secondary"; // Default
                string badgeColor = "bg-secondary-subtle text-secondary";
                string iconColor = "text-secondary";
                string statusText = appt.Status.ToString();
                string statusIcon = "bi-calendar-event";

                switch (appt.Status)
                {
                    case AppointmentStatus.Scheduled:
                        cardTopBorderColor = "border-primary";
                        badgeColor = "bg-primary-subtle text-primary";
                        iconColor = "text-primary";
                        statusIcon = "bi-clock-history";
                        if (isUpcoming) statusText = "Upcoming Visit";
                        break;
                    case AppointmentStatus.Completed:
                        cardTopBorderColor = "border-success";
                        badgeColor = "bg-success-subtle text-success";
                        iconColor = "text-success";
                        statusIcon = "bi-check-circle-fill";
                        break;
                    case AppointmentStatus.Cancelled:
                        cardTopBorderColor = "border-danger";
                        badgeColor = "bg-danger-subtle text-danger";
                        iconColor = "text-danger";
                        statusIcon = "bi-x-circle-fill";
                        break;
                        // Add cases for Rescheduled (warning/amber) if needed
                }
                // -----------------------------------

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden appointment-card border-top border-4 @cardTopBorderColor">

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <span class="badge @badgeColor rounded-pill px-3 py-2 fw-semibold small text-uppercase" style="letter-spacing: 0.03em;">
                                    <i class="bi @statusIcon me-1"></i> @statusText
                                </span>
                                <i class="bi bi-three-dots-vertical text-muted fs-5" role="button" title="Options"></i>
                            </div>

                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-light">
                                <div class="position-relative">
                                    <img src="@(string.IsNullOrEmpty(appt.DoctorPhotoUrl) ? "/images/default-doctor.png" : appt.DoctorPhotoUrl)"
                                         class="rounded-circle border border-3 border-white shadow-sm"
                                         style="width: 70px; height: 70px; object-fit: cover;"
                                         alt="Doctor Photo"
                                         onerror="this.src='/images/default-doctor.png'">
                                    @if (isUpcoming)
                                    {
                                        <span class="position-absolute bottom-0 end-0 bg-success border border-white rounded-circle p-1" title="Online"></span>
                                    }
                                </div>
                                <div class="ms-3">
                                    <h6 class="mb-0 fw-bold text-dark fs-5">@(appt.DoctorName ?? "Specialist")</h6>
                                    <div class="@iconColor small fw-semibold">@appt.DoctorSpecialty</div>
                                </div>
                            </div>

                            <div class="row g-2 mb-4 text-center">
                                <div class="col-6">
                                    <div class="bg-light rounded-3 p-3 h-100">
                                        <small class="text-uppercase text-muted fw-bold d-block mb-1" style="font-size: 0.7rem;">Date</small>
                                        <div class="fw-bold text-dark">@appt.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded-3 p-3 h-100">
                                        <small class="text-uppercase text-muted fw-bold d-block mb-1" style="font-size: 0.7rem;">Time</small>
                                        <div class="fw-bold text-dark">@appt.AppointmentDate.ToString("t")</div>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(appt.Notes))
                            {
                                <div class="mb-4">
                                    <small class="text-muted d-block mb-2 fw-semibold">Reason for Visit:</small>
                                    <div class="p-3 bg-light rounded-3 small text-secondary border-start border-3 @cardTopBorderColor">
                                        <i class="bi bi-pencil-square me-1 @iconColor"></i> "@appt.Notes"
                                    </div>
                                </div>
                            }
                        </div>

                        @if (isUpcoming || appt.Status == AppointmentStatus.Completed || appt.Status == AppointmentStatus.Cancelled)
                        {
                            <div class="card-footer bg-light border-0 px-4 py-3 text-centermt-auto">
                                @if (isUpcoming)
                                {
                                    <div class="d-flex gap-2">
                                        <a href="#" class="btn btn-primary rounded-pill w-100 btn-sm">
                                            <i class="bi bi-camera-video me-1"></i> Join Call
                                        </a>
                                        <form asp-action="Cancel" asp-route-id="@appt.Id" method="post" class="w-100"
                                              onsubmit="return confirm('Are you sure you want to cancel this vital medical appointment?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger w-100 rounded-pill btn-sm">
                                                <i class="bi bi-x-circle me-1"></i> Cancel
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (appt.Status == AppointmentStatus.Completed)
                                {
                                    <a href="#" class="btn btn-success rounded-pill btn-sm px-4">
                                        <i class="bi bi-file-earmark-medical me-1"></i> View Summary
                                    </a>
                                }
                                else if (appt.Status == AppointmentStatus.Cancelled)
                                {
                                    <a asp-action="BrowseDoctors" class="btn btn-outline-primary rounded-pill btn-sm px-4">
                                        <i class="bi bi-calendar-plus me-1"></i> Rebook Now
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-5 shadow-sm border border-primary-subtle border-2">
            <div class="display-1 text-primary-subtle mb-4"><i class="bi bi-calendar2-heart"></i></div>
            <h3 class="fw-bold text-dark">Your Health Journey Starts Here</h3>
            <p class="text-muted fs-5 mb-4">You haven't scheduled any consultations yet.<br> Let's find the right specialist for you.</p>
            <a asp-action="BrowseDoctors" class="btn btn-primary btn-lg rounded-pill shadow">
                Book Your First Appointment
            </a>
        </div>
    }
</div>