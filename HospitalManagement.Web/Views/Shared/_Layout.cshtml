@using HospitalManagement.Core.Entities.Identity
@using Microsoft.AspNetCore.Identity
@using HospitalManagement.Core.Entities;
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | MediCare HMS</title>
    
    <!-- Bootstrap 5 CSS (Included in .NET 8 templates) -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Custom Styles -->
    <link href="~/css/site.css" rel="stylesheet" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    
    <!-- 🔝 TOP NAVIGATION BAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container-fluid">
            <!-- 🏥 Brand Logo -->
            <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <img src="~/images/hp-logo.png"
                     alt="MediCare Logo"
                     style="width: 50px; height: 50px; object-fit: contain; margin-right: 10px;" />

                <span class="fw-bold tracking-tight">MediCare HMS</span>
            </a>

            <!-- 📱 Mobile Menu Toggle -->
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- 🔗 Nav Links Container -->
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="bi bi-house-door me-1"></i> Home
                        </a>
                    </li>
          
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- 📅 Common: All Logged-In Users -->
                        @* <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Appointments")">
                                <i class="bi bi-calendar-check me-1"></i> Appointments
                            </a>
                        </li> *@

                        <!-- 👥 Management: Admin, Doctor, Receptionist -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Receptionist"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-people me-1"></i> Management
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0">
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Patients")"><i class="bi bi-person me-2 text-primary"></i> Patients</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Doctors")"><i class="bi bi-clipboard-pulse me-2 text-success"></i> Doctors</a></li>
                                    
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="@Url.Action("ComingSoon", "Home")"><i class="bi bi-shield-lock me-2 text-warning"></i> Roles & Users</a></li>
                                        <li><a class="dropdown-item" href="@Url.Action("ComingSoon", "Home")"><i class="bi bi-building me-2 text-info"></i> Departments</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- 💰 Billing: Admin & Accountant -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Accountant"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("ComingSoon", "Home")">
                                    <i class="bi bi-receipt me-1"></i> Billing
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Appointments" asp-action="MyAppointments">
                                    <i class="bi bi-calendar-check me-1"></i> My Appointments
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Appointments" asp-action="BrowseDoctors">
                                    <i class="bi bi-search me-1"></i> Find Doctor
                                </a>
                            </li>
                        }

                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="bi bi-house-door me-1"></i> Admin Portal
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="bi bi-house-door me-1"></i> Patient Portal
                            </a>
                        </li>
                    }
                </ul>

                <!-- 🔐 Authentication Section -->
                <ul class="navbar-nav mb-2 mb-lg-0">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- ✅ Logged In: User Profile Dropdown -->
                        
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.FullName ?? currentUser?.Email ?? "User";
                            var userRole = (await UserManager.GetRolesAsync(currentUser!)).FirstOrDefault() ?? "User";
                        
                   
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @displayName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li class="dropdown-header text-muted">
                                    Logged in as <strong>@userRole</strong>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="@Url.Action("EditProfile", "Patients")"><i class="bi bi-person-gear me-2"></i> My Profile</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ComingSoon", "Home")"><i class="bi bi-gear me-2"></i> Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- 🔑 Logged Out: Login & Register -->
                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-lg-2 px-3" href="@Url.Action("Login", "Account")">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-lg-2 px-3" href="@Url.Action("Register", "Account")">
                                <i class="bi bi-person-plus me-1"></i> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- 📄 MAIN CONTENT AREA -->
    <main class="flex-grow-1">
        <div class="container-fluid py-4 px-lg-5">
            @RenderBody()
        </div>
    </main>

    <!-- 📦 SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>