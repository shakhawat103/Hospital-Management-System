@model IEnumerable<HospitalManagement.Core.DTOs.Doctors.DoctorDto> 

@{
    ViewData["Title"] = "Doctors";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Doctor List</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Add New Doctor</a>
    </div>

    <!-- Patients Table -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Specialty</th>      <!-- Added -->
                                <th>License</th>        <!-- Added -->
                                <th>Fee</th>            <!-- Added -->
                                <th>Phone</th>
                                <th>Email</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model)
                            {
                                <tr>
                                    <td><strong>@d.FullName</strong></td>
                                    <td>@d.Specialty</td>                    <!-- Added -->
                                    <td><code class="small">@d.LicenseNumber</code></td>  <!-- Added -->
                                    <td>$@d.ConsultationFee.ToString("F2")</td>           <!-- Added -->
                                    <td>@d.Phone</td>
                                    <td>@d.Email</td>
                         
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@d.Id"
                                               class="btn btn-outline-info">Details</a>
                                            <a asp-action="Edit" asp-route-id="@d.Id"
                                               class="btn btn-outline-warning">Edit</a>
                                            <form asp-action="Delete" asp-route-id="d.Id"
                                                  method="post" class="@d-inline"
                                                  onsubmit="return confirm('Delete @d.FullName?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                    
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <p class="mt-3 text-muted">No doctors found.</p>
                    <a asp-action="Create" class="btn btn-primary">Add Your First Doctor</a>
                </div>
            }
        </div>
    </div>
</div>