@model HospitalManagement.Core.DTOs.Doctors.CreateDoctorDto

@{
    ViewData["Title"] = "Edit Doctor";
    // Determine which photo to show initially
    var displayPhotoUrl = string.IsNullOrEmpty(Model.PhotoUrl)
        ? "/images/default-doctor.png"
        : Model.PhotoUrl;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <!-- Header -->
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">✏️ Edit Doctor #@Model.Id</h4>
                    <a asp-action="Index" class="btn btn-light btn-sm">← Back to List</a>
                </div>

                <div class="card-body">
                    <!-- ✅ CRITICAL: enctype for file uploads -->
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Hidden Fields -->
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PhotoUrl" /> <!-- ✅ Preserves existing URL if no new file -->

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                        <!-- 👨‍⚕️ Profile Photo Section -->
                        <div class="mb-4 text-center p-3 bg-light rounded">
                            <label class="form-label fw-medium mb-2">Profile Photo</label>

                            <!-- Current Photo Display -->
                            <div class="mb-3">
                                <img id="photoPreview"
                                     src="@displayPhotoUrl"
                                     class="img-thumbnail rounded-circle border border-3"
                                     style="width: 120px; height: 120px; object-fit: cover;"
                                     onerror="this.src='/images/default-doctor.png'" />
                            </div>

                            <!-- File Input -->
                            <div class="d-inline-block">
                                <input asp-for="PhotoFile" type="file" class="form-control" accept="image/*"
                                       onchange="previewImage(this, 'photoPreview')" />
                                <small class="text-muted d-block mt-1">
                                    Leave empty to keep current photo. Accepts JPG, PNG, WEBP (max 2MB)
                                </small>
                            </div>
                        </div>

                        <!-- 📝 Doctor Details Form -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label">First Name *</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label">Last Name *</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Specialty" class="form-label">Specialty *</label>
                            <input asp-for="Specialty" class="form-control" placeholder="e.g., Cardiology" />
                            <span asp-validation-for="Specialty" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LicenseNumber" class="form-label">License Number *</label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="e.g., MD-12345" />
                            <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ConsultationFee" class="form-label">Consultation Fee ($) *</label>
                                <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="ConsultationFee" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">Phone *</label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">Email *</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- 🎯 Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">❌ Cancel</a>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">👁️ View</a>
                            <button type="submit" class="btn btn-warning px-4">💾 Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // 🔍 Live preview when a new file is selected
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.add('border-warning');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}